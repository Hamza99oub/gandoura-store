# Server port (default: 9000)
PORT=9000

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/gandoura

# Redis (optional - without Redis, in-memory fallback used)
REDIS_URL=redis://user:password@host:6379

# CORS origins (comma-separated)
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:3000

# Authentication secrets (generate strong random values)
JWT_SECRET=your-jwt-secret-here
COOKIE_SECRET=your-cookie-secret-here

# Admin panel
MEDUSA_ADMIN_ONBOARDING_TYPE=default
ADMIN_PATH=/app
